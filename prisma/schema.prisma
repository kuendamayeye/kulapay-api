// ENUMS


enum EstadoUsuario {
  ACTIVO
  BLOQUEADO
  SUSPENSO
}

enum EstadoCarteira {
  ACTIVA
  CONGELADA
  ENCERRADA
}

enum TipoCarteira {
  PESSOAL
  AGENTE
  COMERCIANTE
  POUPANCA
}


enum EstadoTransaccao {
  PENDENTE
  SUCESSO
  FALHADA
  REVERTIDA
}

enum TipoTransaccao {
  TRANSFERENCIA
  DEPOSITO
  LEVANTAMENTO
  PAGAMENTO
  PAGAMENTO_SERVICO
  RECARGA
  DEPOSITO_POUPANCA
  DESEMBOLSO_CREDITO
  PAGAMENTO_CREDITO
}

enum EstadoCredito {
  PENDENTE
  APROVADO
  REJEITADO
  ACTIVO
  CONCLUIDO
  INCUMPRIDO
}

enum EstadoKyc {
  PENDENTE
  VERIFICADO
  REJEITADO
}

enum CanalNotificacao {
  SMS
  EMAIL
  PUSH
}

enum EstadoNotificacao {
  PENDENTE
  ENVIADA
  FALHADA
}

enum EstadoMembro {
  ACTIVO
  PENDENTE
  SUSPENSO
  SAIU
}

enum EstadoContribuicao {
  PENDENTE
  PAGO
  ATRASADO
  FALHOU
}

enum MetodoPagamento {
  DINHEIRO
  TRANSFERENCIA
  REFERENCIA
  MOBILE_MONEY
}

enum FrequenciaCiclo {
  SEMANAL
  MENSAL
}

enum EstadoConvite {
  PENDENTE
  ACEITE
  EXPIRADO
}


// UTILIZADORES


model Utilizador {
  id                    String   @id @default(uuid()) 

  nomeCompleto          String
  telefone              String   @unique
  email                 String?  @unique

  hashedRt String?

  genero                String?
  dataNascimento        DateTime?

  numeroDocumento       String?

  fotoPerfilUrl         String?

  hashPin               String

  idiomaPreferido       String @default("pt")

  verificado            Boolean @default(false)

  estado                EstadoUsuario @default(ACTIVO)

  criadoEm              DateTime @default(now())
  actualizadoEm         DateTime @updatedAt

  // RELACIONAMENTOS

  enderecos             EnderecoUtilizador[]
  carteiras             Carteira[]
  contasPoupanca        ContaPoupanca[]
  creditos           Credito[]
  documentosKyc         DocumentoKyc[]
  notificacoes          Notificacao[]
  sessoesDispositivo    SessaoDispositivo[]

  agente                Agente?
  comerciante           Comerciante?

  logsAuditoria         LogAuditoria[]

  tokenResets TokenReset[]

  @@index([telefone])
  @@index([numeroDocumento])
  membroGrupos MembroGrupo[]
  grupos Grupo[] @relation("CriadorGrupo")
  contribuicaos Contribuicao[]
}


model TokenReset {
  id         String   @id @default(cuid())
  token      String
  expiryDate DateTime

  utilizadorId String? 
  utilizador   Utilizador?   @relation(fields: [utilizadorId], references: [id])

  @@map("tokens_reset")
}


// ENDEREÇOS
model EnderecoUtilizador {
  id                String @id @default(uuid()) 

  utilizadorId      String 
  utilizador        Utilizador @relation(fields: [utilizadorId], references: [id])

  provincia         String?
  municipio         String?
  comuna            String?
  bairro            String?

  latitude          Decimal? @db.Decimal(10, 7)
  longitude         Decimal? @db.Decimal(10, 7)

  criadoEm          DateTime @default(now())

  @@index([utilizadorId])
}


// CARTEIRAS
model Carteira {
  id                    String @id @default(uuid())

  entidade              String

  referencia            String?

  utilizadorId          String 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  saldo                 Decimal @default(0) @db.Decimal(18, 2)

  moeda                 String @default("AOA")

  tipoCarteira          TipoCarteira @default(PESSOAL)

  estado                EstadoCarteira @default(ACTIVA)

  criadoEm              DateTime @default(now())
  actualizadoEm         DateTime @updatedAt

  transaccoesEnviadas   Transaccao[] @relation("TransaccoesEnviadas")
  transaccoesRecebidas  Transaccao[] @relation("TransaccoesRecebidas")

  creditos           Credito[]

  @@index([utilizadorId])
  contaPoupancas ContaPoupanca[]
}


// TRANSACÇÕES


model Transaccao {
  id                        String @id @default(uuid()) 

  codigoReferencia          String @unique

  carteiraRemetenteId       String? 
  carteiraDestinoId         String? 

  carteiraRemetente         Carteira? @relation("TransaccoesEnviadas", fields: [carteiraRemetenteId], references: [id])

  carteiraDestino           Carteira? @relation("TransaccoesRecebidas",fields: [carteiraDestinoId],references: [id])

  tipoTransaccao            TipoTransaccao

  valor                     Decimal @db.Decimal(18, 2)

  taxa                      Decimal @default(0) @db.Decimal(18, 2)

  moeda                     String @default("AOA")

  estado                    EstadoTransaccao @default(PENDENTE)

  canal                     String?

  descricao                 String?

  criadoEm                  DateTime @default(now())

  concluidoEm               DateTime?

  pagamentoCredito       PagamentoCredito?

  @@index([codigoReferencia])
  @@index([carteiraRemetenteId])
  @@index([carteiraDestinoId])
  @@index([estado])
}


// AGENTES


model Agente {
  id                    String @id @default(uuid()) 

  utilizadorId          String @unique 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  nomeNegocio           String

  codigoAgente          String @unique

  saldoOperacional      Decimal @default(0) @db.Decimal(18, 2)

  estado                String

  criadoEm              DateTime @default(now())

  grupos Grupo[]

  contribuicaos Contribuicao[]
}


// COMERCIANTES


model Comerciante {
  id                    String @id @default(uuid()) 

  utilizadorId          String @unique 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  nomeNegocio           String

  tipoNegocio           String?

  codigoComerciante     String @unique

  qrCode                String?

  estado                String

  criadoEm              DateTime @default(now())
}


// CONTAS DE POUPANÇA


model ContaPoupanca {
  id                    String @id @default(uuid()) 

  utilizadorId          String 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  carteiraId            String 
  carteira              Carteira @relation(fields: [carteiraId], references: [id])

  nome                  String

  valorMeta             Decimal? @db.Decimal(18, 2)

  valorActual           Decimal @default(0) @db.Decimal(18, 2)

  taxaJuro              Decimal? @db.Decimal(5, 2)

  dataMaturidade        DateTime?

  estado                String

  criadoEm              DateTime @default(now())

  @@index([utilizadorId])
}


// EMPRÉSTIMOS


model Credito {
  id                    String @id @default(uuid()) 

  utilizadorId          String 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  carteiraId            String 
  carteira              Carteira @relation(fields: [carteiraId], references: [id])

  valorPrincipal        Decimal @db.Decimal(18, 2)

  taxaJuro              Decimal @db.Decimal(5, 2)

  valorTotal            Decimal @db.Decimal(18, 2)

  valorPago             Decimal @default(0) @db.Decimal(18, 2)

  duracaoMeses          Int

  pontuacaoCredito      Int?

  estado                EstadoCredito @default(PENDENTE)

  aprovadoEm            DateTime?

  vencimentoEm          DateTime?

  criadoEm              DateTime @default(now())

  pagamentos            PagamentoCredito[]

  @@index([utilizadorId])
  @@index([estado])
}


// PAGAMENTOS DE EMPRÉSTIMOS


model PagamentoCredito {
  id                    String @id @default(uuid()) 

  creditoId          String 
  credito            Credito @relation(fields: [creditoId], references: [id])

  transaccaoId          String @unique 
  transaccao            Transaccao @relation(fields: [transaccaoId], references: [id])

  valor                 Decimal @db.Decimal(18, 2)

  pagoEm                DateTime @default(now())

  @@index([creditoId])
}


// DOCUMENTOS KYC


model DocumentoKyc {
  id                    String @id @default(uuid()) 

  utilizadorId          String 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  tipoDocumento         String

  numeroDocumento       String

  frenteDocumentoUrl    String?
  versoDocumentoUrl     String?

  selfieUrl             String?

  estadoVerificacao     EstadoKyc @default(PENDENTE)

  verificadoEm          DateTime?

  criadoEm              DateTime @default(now())

  @@index([utilizadorId])
}


// SESSÕES DE DISPOSITIVO


model SessaoDispositivo {
  id                    String @id @default(uuid()) 

  utilizadorId          String 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  identificadorDispositivo String

  nomeDispositivo       String?

  enderecoIp            String?

  ultimoAcesso          DateTime?

  activa                Boolean @default(true)

  criadoEm              DateTime @default(now())

  @@index([utilizadorId])
}


// NOTIFICAÇÕES


model Notificacao {
  id                    String @id @default(uuid()) 

  utilizadorId          String 
  utilizador            Utilizador @relation(fields: [utilizadorId], references: [id])

  tipo                  String

  titulo                String

  mensagem              String

  canal                 CanalNotificacao

  estado                EstadoNotificacao @default(PENDENTE)

  enviadaEm             DateTime?

  criadoEm              DateTime @default(now())

  @@index([utilizadorId])
}


// LOGS DE AUDITORIA


model LogAuditoria {
  id                    String @id @default(uuid()) 

  utilizadorId          String? 
  utilizador            Utilizador? @relation(fields: [utilizadorId], references: [id])

  accao                 String

  tipoEntidade          String

  entidadeId            String 

  metadados             Json?

  criadoEm              DateTime @default(now())

  @@index([utilizadorId])
  @@index([tipoEntidade])
}


model Grupo {
  id                           String @id @default(uuid())

  nome                         String
  descricao                    String?

  valorPorCiclo                Decimal

  maximoMembros                Int

  frequenciaCiclo              FrequenciaCiclo

  dataInicio                   DateTime

  publico                      Boolean @default(false)

  permitirEntradaAutomatica    Boolean @default(false)

  nivelMinimoConfianca         Int @default(1)

  criadoPorId                  String
  criadoPor                    Utilizador @relation("CriadorGrupo", fields: [criadoPorId], references: [id])

  criadoPorAgenteId            String?
  criadoPorAgente              Agente? @relation(fields: [criadoPorAgenteId], references: [id])

  criadoEm                     DateTime @default(now())

  membros                      MembroGrupo[]
  contribuicoes                Contribuicao[]
  calendarioPagamentos         CalendarioPagamento[]
}


model MembroGrupo {
