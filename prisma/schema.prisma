  utilizadorId               String
  grupoId                    String

  valor                      Decimal

  pagoEm                     DateTime @default(now())

  estado                     EstadoContribuicao

  metodoPagamento            MetodoPagamento

  referencia                 String?


AgenteId            String?
Agente              Agente? @relation(fields: [AgenteId], references: [id])

  utilizador                 Utilizador @relation(fields: [utilizadorId], references: [id])

  grupo                      Grupo @relation(fields: [grupoId], references: [id])
}

model Convite {
  id                         String @id @default(uuid())

  grupoId                    String

  convidadoPorId             String

  utilizadorConvidadoId      String?

  telefone                   String?

  token                      String @unique

  estado                     EstadoConvite

  expiraEm                   DateTime

  criadoEm                   DateTime @default(now())
}

model CalendarioPagamento {
  id                         String @id @default(uuid())

  grupoId                    String

  membroId                   String

  numeroCiclo                Int

  dataPrevista               DateTime

  pago                       Boolean @default(false)

  pagoEm                     DateTime?

  grupo                      Grupo @relation(fields: [grupoId], references: [id])
}